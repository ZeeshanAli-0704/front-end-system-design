          <mxGeometry x="480" y="1250" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="flowStep4" value="4. User Draws&#xa;(tool → element → state)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="1250" width="165" height="50" as="geometry" />
        </mxCell>

        <mxCell id="flowStep5" value="5. Auto-Save&#xa;(debounced → IndexedDB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7b1fa2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="915" y="1250" width="170" height="50" as="geometry" />
        </mxCell>

        <mxCell id="flowStep6" value="6. Collaborate&#xa;(WebSocket + E2EE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1135" y="1250" width="155" height="50" as="geometry" />
        </mxCell>

        <mxCell id="flowStep7" value="7. Export&#xa;(PNG/SVG/JSON)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1340" y="1250" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Flow edges -->
        <mxCell id="edge-f1-f2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#555;strokeWidth=2;" edge="1" parent="1" source="flowStep1" target="flowStep2">
