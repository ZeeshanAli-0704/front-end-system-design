        <mxCell id="flowStep2" value="2. Open IndexedDB&#xa;(restore last scene)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7b1fa2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
