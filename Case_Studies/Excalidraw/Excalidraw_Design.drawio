        <mxCell id="edge-f5-f6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#555;strokeWidth=2;" edge="1" parent="1" source="flowStep5" target="flowStep6">
          <mxGeometry relative="1" as="geometry" />
