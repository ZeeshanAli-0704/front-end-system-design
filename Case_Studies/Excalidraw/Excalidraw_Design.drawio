        <mxCell id="flowStep1" value="1. App Loads&#xa;(Static HTML from CDN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#283593;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="1250" width="165" height="50" as="geometry" />
