        </mxCell>
        <mxCell id="edge-sum-fare" style="endArrow=block;strokeColor=#e65100;" edge="1" parent="1" source="stateSummary" target="fareSummary">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="starRating" value="StarRating&#xa;(1-5 stars + feedback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="260" y="1185" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-sum-rating" style="endArrow=block;strokeColor=#e65100;" edge="1" parent="1" source="stateSummary" target="starRating">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="tipSelector" value="TipSelector&#xa;(preset + custom amounts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="1185" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-sum-tip" style="endArrow=block;strokeColor=#e65100;" edge="1" parent="1" source="stateSummary" target="tipSelector">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== RIDE STATE MACHINE FLOW ==================== -->
        <mxCell id="smLabel" value="Ride State Machine Flow" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="1290" width="250" height="25" as="geometry" />
        </mxCell>

        <mxCell id="sm-idle" value="IDLE" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="1330" width="100" height="50" as="geometry" />
        </mxCell>

        <mxCell id="sm-destset" value="DESTINATION&#xa;SET" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="1330" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-sm-1" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="sm-idle" target="sm-destset">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="sm-matching" value="MATCHING" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="1330" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-sm-2" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="sm-destset" target="sm-matching">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="sm-assigned" value="DRIVER&#xa;ASSIGNED" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="1330" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-sm-3" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="sm-matching" target="sm-assigned">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="sm-arrived" value="DRIVER&#xa;ARRIVED" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="1330" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-sm-4" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="sm-assigned" target="sm-arrived">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="sm-intrip" value="IN_TRIP" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="950" y="1330" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-sm-5" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="sm-arrived" target="sm-intrip">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="sm-completed" value="COMPLETED" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1130" y="1330" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-sm-6" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="sm-intrip" target="sm-completed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- WebSocket note at bottom -->
        <mxCell id="note-ws" value="WebSocket: wss://api/rides/:id/track&#xa;→ driver location (every 3-5s), status changes, ETA updates&#xa;→ fallback: REST polling every 5s on disconnect" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#b7a500;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="1420" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- State stores note -->
        <mxCell id="note-state" value="State: Zustand (ride state machine)&#xa;Server Data: React Query (history, places)&#xa;Real-time: WebSocket → Zustand store&#xa;Map: Imperative via Google Maps SDK refs" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#b7a500;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="1420" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- Marker animation note -->
        <mxCell id="note-animation" value="Driver Marker: Ease-out cubic interpolation&#xa;via requestAnimationFrame (1.5s duration)&#xa;→ smooth gliding, no teleporting" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#b7a500;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="1420" width="250" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="Data Flow and Ride Lifecycle" id="ride-hailing-data-flow">
    <mxGraphModel dx="2200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="df-title" value="Uber / Ola — Data Flow and Ride Lifecycle" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=20;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== RIDE FLOW ==================== -->
        <mxCell id="flow-title" value="Complete Ride Flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="360" height="50" as="geometry" />
        </mxCell>

        <!-- Step 1: Detect Location -->
        <mxCell id="step1" value="1. Detect Location&#xa;Geolocation API / Saved Address" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Step 2: Show Map + Nearby Drivers -->
        <mxCell id="step2" value="2. Show Map + Nearby Drivers&#xa;GET /api/drivers/nearby?lat=...&amp;lng=..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="350" y="180" width="310" height="60" as="geometry" />
        </mxCell>
        <mxCell id="edge-s1-s2" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#43a047;strokeWidth=2;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: Enter Destination -->
        <mxCell id="step3" value="3. Enter Destination&#xa;Google Places Autocomplete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="710" y="180" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="edge-s2-s3" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;strokeWidth=2;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 4: Fare Estimates -->
        <mxCell id="step4" value="4. Fetch Fare Estimates&#xa;POST /api/fare/estimate&#xa;→ route polyline + estimates for all ride types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="180" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-s3-s4" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#fb8c00;strokeWidth=2;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 5: Select Ride Type + Request -->
        <mxCell id="step5" value="5. Select Ride Type + Request&#xa;POST /api/rides/request&#xa;→ returns rideId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-s4-s5" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#3f51b5;strokeWidth=2;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 6: WebSocket Connect + Matching -->
        <mxCell id="step6" value="6. WebSocket Connect&#xa;wss://api/rides/:id/track&#xa;MATCHING → Finding driver..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="330" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-s5-s6" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#7b1fa2;strokeWidth=2;" edge="1" parent="1" source="step5" target="step6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 7: Driver Matched -->
        <mxCell id="step7" value="7. Driver Matched&#xa;WS: DRIVER_MATCHED event&#xa;→ show driver, vehicle, OTP, ETA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="330" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-s6-s7" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#7b1fa2;strokeWidth=2;" edge="1" parent="1" source="step6" target="step7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 8: Track Driver to Pickup -->
        <mxCell id="step8" value="8. Track Driver to Pickup&#xa;WS: DRIVER_LOCATION every 3-5s&#xa;→ animated marker on map + ETA countdown" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1050" y="330" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-s7-s8" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#1565c0;strokeWidth=2;" edge="1" parent="1" source="step7" target="step8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 9: Driver Arrives -->
        <mxCell id="step9" value="9. Driver Arrives&#xa;WS: DRIVER_ARRIVED&#xa;→ &quot;Your ride is here&quot; + OTP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="480" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-s8-s9" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#1565c0;strokeWidth=2;" edge="1" parent="1" source="step8" target="step9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 10: Trip Starts -->
        <mxCell id="step10" value="10. Trip Started&#xa;WS: TRIP_STARTED&#xa;→ live tracking to destination&#xa;→ route split: completed (gray) + remaining (blue)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="480" width="330" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-s9-s10" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#1565c0;strokeWidth=2;" edge="1" parent="1" source="step9" target="step10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 11: Trip Completed -->
        <mxCell id="step11" value="11. Trip Completed&#xa;WS: TRIP_COMPLETED&#xa;→ fare summary with breakdown" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="750" y="480" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-s10-s11" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#2e7d32;strokeWidth=2;" edge="1" parent="1" source="step10" target="step11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 12: Rate + Tip -->
        <mxCell id="step12" value="12. Rate + Tip&#xa;POST /api/rides/:id/rate&#xa;→ back to IDLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1070" y="480" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-s11-s12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#e65100;strokeWidth=2;" edge="1" parent="1" source="step11" target="step12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== API SUMMARY ==================== -->
        <mxCell id="api-title" value="API Endpoints Summary" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontStyle=1;fontSize=16;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- REST APIs -->
        <mxCell id="api-rest-title" value="REST APIs" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#356ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="660" width="200" height="25" as="geometry" />
        </mxCell>

        <mxCell id="api1" value="GET /api/drivers/nearby&#xa;Nearby driver locations for map" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="695" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="api2" value="POST /api/fare/estimate&#xa;Fare estimates for all ride types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="745" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="api3" value="POST /api/rides/request&#xa;Request a new ride → rideId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="795" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="api4" value="GET /api/rides/active&#xa;Check for in-progress ride (reload recovery)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="845" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="api5" value="POST /api/rides/:id/cancel&#xa;Cancel in-progress ride" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="895" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="api6" value="POST /api/rides/:id/rate&#xa;Submit rating, feedback, tip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="945" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="api7" value="GET /api/rides/history&#xa;Paginated ride history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="995" width="250" height="40" as="geometry" />
        </mxCell>

        <!-- WebSocket and Real-time -->
        <mxCell id="api-ws-title" value="WebSocket (Real Time)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#7b1fa2;" vertex="1" parent="1">
          <mxGeometry x="400" y="660" width="250" height="25" as="geometry" />
        </mxCell>

        <mxCell id="ws1" value="wss://api/rides/:id/track&#xa;Real-time ride tracking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontStyle=1;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="695" width="260" height="45" as="geometry" />
        </mxCell>

        <mxCell id="ws-events" value="Server → Client Events:&#xa;• DRIVER_LOCATION (lat, lng, heading) — every 3-5s&#xa;• ETA_UPDATE (etaMinutes) — every 10-30s&#xa;• DRIVER_MATCHED (driver info, OTP)&#xa;• DRIVER_ARRIVED&#xa;• TRIP_STARTED&#xa;• TRIP_COMPLETED (fare summary)&#xa;• RIDE_CANCELLED (reason)&#xa;• ROUTE_UPDATE (new polyline)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="755" width="300" height="160" as="geometry" />
        </mxCell>

        <mxCell id="ws-fallback" value="Fallback: GET /api/rides/:id/status&#xa;REST polling every 5s on WebSocket disconnect&#xa;Reconnect: exponential backoff (1s, 2s, 4s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#e53935;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="930" width="300" height="60" as="geometry" />
        </mxCell>

        <!-- State Management -->
        <mxCell id="state-title" value="State Management" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="800" y="660" width="200" height="25" as="geometry" />
        </mxCell>

        <mxCell id="state-zustand" value="Zustand Store (Ride State Machine)&#xa;• state: IDLE | DESTINATION_SET | MATCHING | ...&#xa;• pickup / dropoff locations&#xa;• driver info, location, OTP&#xa;• fare estimates, route polyline&#xa;• ETA, ride summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="695" width="300" height="110" as="geometry" />
        </mxCell>

        <mxCell id="state-rq" value="React Query (Server State)&#xa;• Saved places, payment methods&#xa;• Ride history (paginated)&#xa;• Fare estimates (on demand)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="820" width="300" height="80" as="geometry" />
        </mxCell>

        <mxCell id="state-local" value="localStorage&#xa;• Last pickup, recent searches&#xa;• Map preferences" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="915" width="300" height="55" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
