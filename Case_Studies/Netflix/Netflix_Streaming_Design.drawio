  <diagram name="Data Flow and Streaming" id="netflix-data-flow">
    <mxGraphModel dx="2400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="df-title" value="Netflix Streaming — Data Flow, Playback, and API Design" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=20;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="750" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== BROWSE FLOW ==================== -->
        <mxCell id="flow-title" value="Browse Page Loading Flow (Phased)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e50914;strokeColor=#b2070f;fontStyle=1;fontSize=16;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="450" y="80" width="450" height="50" as="geometry" />
        </mxCell>

        <mxCell id="fl1" value="1. Profile selected →&#xa;SSR renders billboard&#xa;+ first 4 rows" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fl2" value="2. Browser paints&#xa;artwork + posters&#xa;(fast FCP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="170" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fl3" value="3. JS hydrates →&#xa;billboard trailer&#xa;starts (2s delay)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="170" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fl4" value="4. Fetch next 5 rows&#xa;(client-side batch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="170" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fl5" value="5. Scroll → lazy rows&#xa;loaded via Intersection&#xa;Observer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="170" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fl6" value="6. Hover title card →&#xa;expand + preview clip&#xa;after delay" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="170" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="edge-fl12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl1" target="fl2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fl23" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl2" target="fl3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fl34" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl3" target="fl4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fl45" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl4" target="fl5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fl56" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl5" target="fl6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== PLAYBACK FLOW ==================== -->
        <mxCell id="play-title" value="Video Playback Flow (Click to First Frame)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e50914;strokeColor=#b2070f;fontStyle=1;fontSize=16;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="450" y="290" width="450" height="50" as="geometry" />
        </mxCell>

        <mxCell id="pl1" value="1. User clicks Play →&#xa;load player chunk&#xa;(code-split)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="pl2" value="2. Fetch DASH manifest&#xa;(.mpd) from CDN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="380" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="pl3" value="3. Acquire DRM license&#xa;(EME + Widevine/FairPlay)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="380" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="pl4" value="4. ABR selects quality →&#xa;fetch first segments →&#xa;decrypt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="380" width="190" height="55" as="geometry" />
        </mxCell>
        <mxCell id="pl5" value="5. First frame decoded&#xa;→ playback starts&#xa;(resume from progress)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="910" y="380" width="190" height="55" as="geometry" />
        </mxCell>
        <mxCell id="pl6" value="6. Continuous ABR:&#xa;monitor bandwidth →&#xa;switch quality per segment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1130" y="380" width="200" height="55" as="geometry" />
        </mxCell>

        <mxCell id="edge-pl12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="pl1" target="pl2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-pl23" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="pl2" target="pl3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-pl34" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="pl3" target="pl4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-pl45" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="pl4" target="pl5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-pl56" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="pl5" target="pl6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== EPISODE FLOW ==================== -->
        <mxCell id="ep-title" value="Episode Lifecycle (Skip Intro → Auto Next)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e50914;strokeColor=#b2070f;fontStyle=1;fontSize=16;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="450" y="490" width="450" height="50" as="geometry" />
        </mxCell>

        <mxCell id="ep1" value="Episode starts →&#xa;restore watch progress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="580" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ep2" value="currentTime hits&#xa;skipRecap.start →&#xa;show Skip Recap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="580" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ep3" value="currentTime hits&#xa;skipIntro.start →&#xa;show Skip Intro" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="580" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ep4" value="currentTime hits&#xa;skipCredits →&#xa;show Next Episode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="580" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ep5" value="15s countdown →&#xa;auto-load next&#xa;episode manifest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="580" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ep6" value="Seamless transition&#xa;→ next episode plays&#xa;→ progress updated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1130" y="580" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="edge-ep12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="ep1" target="ep2">
