        <mxCell id="api5" value="PUT /api/history/:contentId&#xa;POST /api/mylist/:titleId&#xa;POST /api/ratings/:titleId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;fontStyle=1;" vertex="1" parent="1">
