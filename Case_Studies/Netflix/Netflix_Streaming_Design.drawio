        <mxCell id="edge-ep56" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="ep5" target="ep6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== API DESIGN ==================== -->
        <mxCell id="api-title" value="Key Frontend APIs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e50914;strokeColor=#b2070f;fontStyle=1;fontSize=16;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="160" y="690" width="300" height="50" as="geometry" />
        </mxCell>

        <mxCell id="api1" value="GET /api/browse&#xa;→ billboard + first 4 rows&#xa;(SSR critical path)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="780" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="api2" value="GET /api/browse/rows&#xa;?offset=4&amp;limit=5&#xa;→ lazy batch rows" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="780" width="200" height="60" as="geometry" />
