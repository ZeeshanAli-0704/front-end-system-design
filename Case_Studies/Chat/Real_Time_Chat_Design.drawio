        <mxCell id="opt4" value="4. Server ACK&#xa;→ status: 'sent' ✓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="840" y="1230" width="200" height="55" as="geometry" />
