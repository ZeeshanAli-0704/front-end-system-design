        <!-- ==================== DEBOUNCE AND REQUEST FLOW ==================== -->
        <mxCell id="debounce-title" value="Request Lifecycle — Debounce, Abort, Cache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="400" y="700" width="480" height="60" as="geometry" />
        </mxCell>

        <mxCell id="step1" value="1. User types character&#xa;(onChange fires)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="830" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="edge-d-s1" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;strokeWidth=2;" edge="1" parent="1" source="debounce-title" target="step1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="step2" value="2. Debounce timer starts&#xa;(150ms desktop / 250ms mobile)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="830" width="240" height="55" as="geometry" />
        </mxCell>
        <mxCell id="edge-s12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="step3" value="3. Check client LRU cache&#xa;(50 entries, 5min TTL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="830" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="edge-s23" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="step4a" value="4a. Cache HIT&#xa;→ Render instantly (0ms)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="460" y="940" width="210" height="55" as="geometry" />
        </mxCell>
        <mxCell id="edge-s3-4a" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#2e7d32;strokeWidth=2;" edge="1" parent="1" source="step3" target="step4a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="step4b" value="4b. Cache MISS&#xa;→ Abort previous fetch&#xa;→ Fire new API request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="940" width="230" height="65" as="geometry" />
        </mxCell>
        <mxCell id="edge-s3-4b" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#e53935;strokeWidth=2;" edge="1" parent="1" source="step3" target="step4b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="step5" value="5. Response arrives →&#xa;Version check (stale?) →&#xa;Cache result → Render" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="940" width="230" height="65" as="geometry" />
        </mxCell>
        <mxCell id="edge-s4b-5" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="step4b" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== RACE CONDITION HANDLING ==================== -->
        <mxCell id="race-title" value="Race Condition Prevention" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="400" y="1080" width="480" height="60" as="geometry" />
        </mxCell>

        <mxCell id="race-abort" value="AbortController&#xa;Cancel previous in-flight request&#xa;before sending new one&#xa;(saves bandwidth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8e24aa;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="140" y="1200" width="280" height="70" as="geometry" />
