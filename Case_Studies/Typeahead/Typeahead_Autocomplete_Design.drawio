        <mxCell id="recentSearches" value="RecentSearchesSection&#xa;(input empty + focused → from localStorage)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb8c00;fontSize=11;" vertex="1" parent="1">
