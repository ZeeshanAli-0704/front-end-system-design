          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="race-version" value="Request Versioning (useRef)&#xa;Increment requestId on each fetch&#xa;Discard response if id != latest&#xa;(safety net)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8e24aa;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="1200" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-race-version" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#8e24aa;strokeWidth=2;" edge="1" parent="1" source="race-title" target="race-version">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="race-cleanup" value="Cleanup on Unmount&#xa;Abort all in-flight on&#xa;useEffect cleanup&#xa;(prevent memory leaks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8e24aa;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="1200" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge-race-cleanup" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#8e24aa;strokeWidth=2;" edge="1" parent="1" source="race-title" target="race-cleanup">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

