        <!-- ==================== VIDEO WATCH FLOW ==================== -->
        <mxCell id="flow-title" value="Video Watch Page Flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="400" height="50" as="geometry" />
        </mxCell>

        <mxCell id="fl1" value="1. Navigate to /watch?v=abc&#xa;SSR renders metadata shell" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl2" value="2. Browser preloads&#xa;HLS manifest (m3u8)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="170" width="190" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl3" value="3. JS hydrates, Player&#xa;mounts, hls.js loads manifest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="170" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl4" value="4. ABR selects quality,&#xa;fetches first segments" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="170" width="190" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl5" value="5. First frame decoded&#xa;→ playback starts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="170" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl6" value="6. Comments + Recs&#xa;lazy loaded below fold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="170" width="190" height="55" as="geometry" />
        </mxCell>

        <mxCell id="edge-fl12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl1" target="fl2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fl23" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl2" target="fl3">
