        <mxCell id="edge-abr45" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="abr4" target="abr5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-abr-loop" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#e53935;strokeWidth=1;dashed=1;entryX=0.5;entryY=1;exitX=0.5;exitY=1;" edge="1" parent="1" source="abr5" target="abr2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1045" y="460" />
              <mxPoint x="370" y="460" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ==================== API DESIGN ==================== -->
        <mxCell id="api-title" value="Key Frontend APIs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="160" y="510" width="300" height="50" as="geometry" />
        </mxCell>

        <mxCell id="api1" value="GET /api/videos/:id&#xa;→ metadata + manifestUrl + captions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="api2" value="GET /api/videos/:id/recommendations&#xa;→ cursor-based video list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="600" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="api3" value="GET /api/videos/:id/comments&#xa;?sort=top&amp;cursor=abc&#xa;→ paginated comments" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="600" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="api4" value="GET /api/feed&#xa;?cursor=xyz&amp;category=trending&#xa;→ personalized video grid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="600" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="api5" value="POST /api/videos/:id/like&#xa;POST /api/videos/:id/comments&#xa;(optimistic updates)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1110" y="600" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- ==================== PLAYER STATE MACHINE ==================== -->
        <mxCell id="state-title" value="Video Player State Machine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="160" y="720" width="360" height="50" as="geometry" />
        </mxCell>

        <mxCell id="st-idle" value="IDLE" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="820" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="st-loading" value="LOADING" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="820" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="st-ready" value="READY" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="820" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="st-playing" value="PLAYING" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="530" y="820" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="st-paused" value="PAUSED" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="820" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="st-buffering" value="BUFFERING" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="530" y="910" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="st-ended" value="ENDED" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="820" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="st-error" value="ERROR" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="910" width="100" height="50" as="geometry" />
        </mxCell>

        <mxCell id="edge-st-12" value="loadSource" style="endArrow=block;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="st-idle" target="st-loading">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-st-23" value="canplay" style="endArrow=block;strokeColor=#43a047;fontSize=10;" edge="1" parent="1" source="st-loading" target="st-ready">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-st-34" value="play()" style="endArrow=block;strokeColor=#1e88e5;fontSize=10;" edge="1" parent="1" source="st-ready" target="st-playing">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-st-45" value="pause()" style="endArrow=block;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="st-playing" target="st-paused">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-st-4b" value="waiting" style="endArrow=block;strokeColor=#e53935;fontSize=10;" edge="1" parent="1" source="st-playing" target="st-buffering">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-st-b4" value="playing" style="endArrow=block;strokeColor=#1e88e5;fontSize=10;" edge="1" parent="1" source="st-buffering" target="st-playing">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-st-5e" value="ended" style="endArrow=block;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="st-paused" target="st-ended">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-st-err" value="error" style="endArrow=block;strokeColor=#e53935;fontSize=10;dashed=1;" edge="1" parent="1" source="st-playing" target="st-error">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== CACHING LAYERS ==================== -->
        <mxCell id="cache-title" value="Caching Layers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="160" y="1010" width="300" height="50" as="geometry" />
        </mxCell>

        <mxCell id="cache1" value="React Query Cache&#xa;(video metadata, feed, comments&#xa;stale-while-revalidate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1100" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cache2" value="HTTP Browser Cache&#xa;(video segments .ts/.m4s&#xa;immutable, long TTL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="1100" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cache3" value="Service Worker Cache&#xa;(app shell, JS, CSS, fonts&#xa;precached on install)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="1100" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cache4" value="localStorage&#xa;(watch progress, volume,&#xa;playback speed, captions pref)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="1100" width="210" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cache-cdn" value="CDN Edge Servers&#xa;(multi-region, segments +&#xa;thumbnails + manifests)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1010" y="1100" width="210" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
