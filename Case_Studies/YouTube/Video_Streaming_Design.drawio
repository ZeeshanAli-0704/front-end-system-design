          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== ADAPTIVE STREAMING FLOW ==================== -->
        <mxCell id="abr-title" value="Adaptive Bitrate Streaming Flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="160" y="290" width="380" height="50" as="geometry" />
        </mxCell>

        <mxCell id="abr1" value="Fetch master.m3u8&#xa;(lists all quality levels)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="abr2" value="Estimate bandwidth&#xa;from recent downloads" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="380" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="abr3" value="Select highest quality&#xa;that fits bandwidth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="380" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="abr4" value="Fetch next segment&#xa;at selected quality" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="380" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="abr5" value="Decode and render&#xa;→ loop back to step 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="950" y="380" width="190" height="50" as="geometry" />
        </mxCell>

        <mxCell id="edge-abr12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="abr1" target="abr2">
