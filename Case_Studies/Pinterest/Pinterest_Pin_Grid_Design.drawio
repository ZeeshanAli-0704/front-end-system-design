          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="masonry-step3" value="3. Place in shortest column&#xa;argmin(columnHeights)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=12;" vertex="1" parent="1">
