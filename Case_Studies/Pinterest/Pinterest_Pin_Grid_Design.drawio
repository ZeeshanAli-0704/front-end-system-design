        <mxCell id="masonry-step2" value="2. Compute cardHeight =&#xa;(imgH / imgW) * colWidth + footer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=12;" vertex="1" parent="1">
