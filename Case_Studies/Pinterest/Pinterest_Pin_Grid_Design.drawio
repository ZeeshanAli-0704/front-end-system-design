          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="masonry-step4" value="4. Position via transform:&#xa;translate(left, top) — GPU accel." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=12;" vertex="1" parent="1">
