        <mxCell id="postActions" value="PostActions&#xa;(Like + Comment + Share buttons)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="540" width="240" height="55" as="geometry" />
