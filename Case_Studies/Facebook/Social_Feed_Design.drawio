        <mxCell id="postMedia" value="PostMedia&#xa;├── SingleImage&#xa;├── ImageCarousel&#xa;├── VideoPlayer&#xa;└── LinkPreviewCard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#356ebf;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="610" y="530" width="200" height="90" as="geometry" />
