        <mxCell id="feedList" value="FeedList&#xa;(virtualized / windowed scroll container)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;" vertex="1" parent="1">
