  <diagram name="Data Flow and API" id="social-feed-data-flow">
    <mxGraphModel dx="2200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="df-title" value="Social Feed — Data Flow and API Design" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=20;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== COMPLETE FEED FLOW ==================== -->
        <mxCell id="flow-title" value="Complete Feed Flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="360" height="50" as="geometry" />
        </mxCell>

        <mxCell id="fl1" value="1. App opens →&#xa;SSR renders shell + first 10 posts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl2" value="2. Client hydrates →&#xa;GET /api/feed?limit=10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="170" width="190" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl3" value="3. SSE connects →&#xa;GET /api/feed/stream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="170" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl4" value="4. Scroll → sentinel →&#xa;GET /api/feed?cursor=abc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="170" width="190" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl5" value="5. New post arrives →&#xa;buffer + banner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="170" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fl6" value="6. User taps banner →&#xa;prepend to feed + scroll top" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="170" width="200" height="55" as="geometry" />
        </mxCell>

        <mxCell id="edge-fl12" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl1" target="fl2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fl23" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl2" target="fl3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fl34" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl3" target="fl4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fl45" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl4" target="fl5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fl56" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="fl5" target="fl6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-flow-top" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;strokeWidth=2;" edge="1" parent="1" source="flow-title" target="fl1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== CURSOR-BASED PAGINATION ==================== -->
        <mxCell id="cursor-title" value="Cursor-Based Pagination" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="160" y="300" width="340" height="50" as="geometry" />
        </mxCell>

        <mxCell id="cur1" value="GET /api/feed?limit=10&#xa;→ {posts: [...], nextCursor: &quot;abc123&quot;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cur2" value="GET /api/feed?cursor=abc123&#xa;→ {posts: [...], nextCursor: &quot;def456&quot;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cur3" value="GET /api/feed?cursor=def456&#xa;→ {posts: [...], nextCursor: null}&#xa;(no more pages)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="530" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="edge-cur12" style="endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="cur1" target="cur2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-cur23" style="endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="cur2" target="cur3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-cursor-top" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;strokeWidth=2;" edge="1" parent="1" source="cursor-title" target="cur1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Cursor vs Offset comparison note -->
        <mxCell id="cursor-note" value="Why Cursor over Offset?&#xa;&#xa;• No duplicate posts on insert&#xa;• No missing posts on delete&#xa;• Fast at deep pages (no OFFSET N)&#xa;• Standard for social feeds" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#b7a500;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="350" y="390" width="220" height="120" as="geometry" />
        </mxCell>

        <!-- ==================== REAL-TIME UPDATES ==================== -->
        <mxCell id="rt-title" value="Real-Time Update Strategy (SSE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="780" y="300" width="380" height="50" as="geometry" />
        </mxCell>

        <mxCell id="rt-sse" value="SSE: GET /api/feed/stream&#xa;(server → client push)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="650" y="400" width="240" height="55" as="geometry" />
        </mxCell>
        <mxCell id="edge-rt-sse" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#fb8c00;strokeWidth=2;" edge="1" parent="1" source="rt-title" target="rt-sse">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="rt-poll" value="Polling Fallback&#xa;(every 60s if SSE fails)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="930" y="400" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="edge-rt-poll" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#fb8c00;strokeWidth=2;" edge="1" parent="1" source="rt-title" target="rt-poll">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SSE event types -->
        <mxCell id="sse-new" value="event: new_post&#xa;→ add to newPostsBuffer&#xa;→ show banner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="490" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="sse-engage" value="event: engagement_update&#xa;→ update likeCount,&#xa;  commentCount on visible post" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="490" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="edge-sse-new" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#43a047;" edge="1" parent="1" source="rt-sse" target="sse-new">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-sse-engage" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#43a047;" edge="1" parent="1" source="rt-sse" target="sse-engage">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SSE comparison note -->
        <mxCell id="rt-note" value="SSE vs WebSocket vs Polling&#xa;&#xa;• SSE: simple, auto-reconnect, HTTP/2 friendly&#xa;• WebSocket: bidirectional (overkill for feeds)&#xa;• Polling: fallback only, higher latency&#xa;&#xa;→ SSE is the recommended choice for feeds" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#b7a500;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="390" width="270" height="130" as="geometry" />
        </mxCell>

        <!-- ==================== OPTIMISTIC UPDATES ==================== -->
        <mxCell id="opt-title" value="Optimistic Update Flow (Like)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="300" y="650" width="380" height="50" as="geometry" />
        </mxCell>

        <mxCell id="opt1" value="User taps Like →&#xa;UI updates instantly&#xa;(isLiked=true, count+1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="750" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="opt2" value="Background API →&#xa;POST /api/post/:id/like" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="750" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="opt3-ok" value="API Success →&#xa;done (state already correct)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="730" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="opt3-fail" value="API Fails →&#xa;ROLLBACK (isLiked=false, count-1)&#xa;+ show error toast" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="790" width="230" height="55" as="geometry" />
        </mxCell>

        <mxCell id="edge-opt12" style="endArrow=block;strokeColor=#666666;strokeWidth=2;" edge="1" parent="1" source="opt1" target="opt2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-opt3ok" style="endArrow=block;strokeColor=#43a047;strokeWidth=2;" edge="1" parent="1" source="opt2" target="opt3-ok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-opt3fail" style="endArrow=block;strokeColor=#e53935;strokeWidth=2;" edge="1" parent="1" source="opt2" target="opt3-fail">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-opt-top" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#8e24aa;strokeWidth=2;" edge="1" parent="1" source="opt-title" target="opt1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== ENDPOINT SUMMARY ==================== -->
        <mxCell id="api-title" value="API Endpoint Summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="300" y="920" width="380" height="50" as="geometry" />
        </mxCell>

        <mxCell id="api1" value="GET /api/feed&#xa;(cursor-based pagination)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1020" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="api2" value="GET /api/feed/stream&#xa;(SSE — real-time push)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="1020" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="api3" value="POST /api/post&#xa;(create new post)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="1020" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="api4" value="POST /api/post/:id/like&#xa;(like or unlike)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="1020" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="api5" value="POST /api/post/:id/comment&#xa;(add comment)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="1020" width="200" height="50" as="geometry" />
