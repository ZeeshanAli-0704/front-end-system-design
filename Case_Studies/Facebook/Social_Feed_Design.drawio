        <mxCell id="feedSentinel" value="FeedSentinel&#xa;(IntersectionObserver trigger)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1060" y="230" width="260" height="60" as="geometry" />
