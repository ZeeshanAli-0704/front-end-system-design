        <mxCell id="api6" value="POST /api/post/:id/share&#xa;(share or repost)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
