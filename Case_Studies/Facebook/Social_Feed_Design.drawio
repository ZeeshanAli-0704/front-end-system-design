  <diagram name="Infinite Scroll and Virtualization" id="social-feed-scroll-virt">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="sv-title" value="Feed List — Infinite Scroll and Virtualization Strategy" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=20;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="650" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== INFINITE SCROLL ==================== -->
        <mxCell id="is-title" value="Infinite Scroll — IntersectionObserver Pattern" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="120" y="80" width="420" height="55" as="geometry" />
        </mxCell>

        <!-- Scroll diagram -->
        <mxCell id="is-viewport" value="Viewport (visible area)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="120" y="160" width="250" height="180" as="geometry" />
        </mxCell>
        <mxCell id="is-p1" value="PostCard 1 ✅ visible" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="190" width="210" height="35" as="geometry" />
        </mxCell>
        <mxCell id="is-p2" value="PostCard 2 ✅ visible" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="235" width="210" height="35" as="geometry" />
        </mxCell>
        <mxCell id="is-p3" value="PostCard 3 ✅ visible (bottom)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="280" width="210" height="35" as="geometry" />
        </mxCell>

        <mxCell id="is-below" value="Below Viewport" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontStyle=1;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="120" y="355" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="is-p4" value="PostCard 4 (below)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="385" width="210" height="30" as="geometry" />
        </mxCell>
        <mxCell id="is-p5" value="PostCard 5 (below)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="425" width="210" height="30" as="geometry" />
        </mxCell>
        <mxCell id="is-sentinel" value="🔽 SENTINEL (0px height)&#xa;→ triggers fetch when enters rootMargin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="465" width="210" height="40" as="geometry" />
        </mxCell>

        <mxCell id="is-margin" value="rootMargin: 500px ↓&#xa;(fires fetch 500px BEFORE&#xa; sentinel is visible)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#b7a500;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="380" width="200" height="65" as="geometry" />
        </mxCell>

        <!-- ==================== VIRTUALIZATION ==================== -->
        <mxCell id="virt-title" value="Feed Virtualization — Variable Height Items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="420" height="55" as="geometry" />
        </mxCell>

        <!-- Three-layer structure -->
        <mxCell id="vl-outer" value="Layer 1: Outer Scroll Container&#xa;(overflow: auto, height: 100vh)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1e88e5;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="170" width="290" height="55" as="geometry" />
        </mxCell>
        <mxCell id="vl-spacer" value="Layer 2: Inner Spacer&#xa;(height = sum of all item heights,&#xa; measured + estimated)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1020" y="170" width="260" height="65" as="geometry" />
        </mxCell>
        <mxCell id="vl-items" value="Layer 3: Absolute Positioned Items&#xa;(only visible + overscan buffer)&#xa;transform: translateY(start)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="830" y="260" width="290" height="65" as="geometry" />
        </mxCell>

        <mxCell id="edge-vl-1" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#8e24aa;strokeWidth=2;" edge="1" parent="1" source="virt-title" target="vl-outer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-vl-2" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#8e24aa;strokeWidth=2;" edge="1" parent="1" source="virt-title" target="vl-spacer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-vl-3" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#8e24aa;strokeWidth=2;" edge="1" parent="1" source="virt-title" target="vl-items">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Dynamic measurement flow -->
        <mxCell id="dm-title" value="Dynamic Height Measurement Flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="780" y="370" width="370" height="45" as="geometry" />
        </mxCell>

        <mxCell id="dm1" value="Item mounts →&#xa;estimates height (400px)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8e24aa;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="450" width="190" height="45" as="geometry" />
        </mxCell>
        <mxCell id="dm2" value="measureElement fires →&#xa;records real height (520px)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8e24aa;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="870" y="450" width="200" height="45" as="geometry" />
        </mxCell>
        <mxCell id="dm3" value="Spacer + positions recalculated&#xa;(total height converges)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8e24aa;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1090" y="450" width="210" height="45" as="geometry" />
        </mxCell>
        <mxCell id="edge-dm12" style="endArrow=block;strokeColor=#8e24aa;strokeWidth=2;" edge="1" parent="1" source="dm1" target="dm2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-dm23" style="endArrow=block;strokeColor=#8e24aa;strokeWidth=2;" edge="1" parent="1" source="dm2" target="dm3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Performance comparison -->
        <mxCell id="perf-compare" value="Performance: Virtualized vs Not" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="120" y="570" width="340" height="45" as="geometry" />
        </mxCell>

        <mxCell id="perf-no" value="No Virtualization (500 posts)&#xa;&#xa;• ~15,000+ DOM nodes&#xa;• Initial render: 500ms-2s&#xa;• Memory: all images decoded&#xa;• Scroll: degrades with count" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="650" width="230" height="120" as="geometry" />
        </mxCell>
        <mxCell id="perf-yes" value="Virtualized (overscan=3)&#xa;&#xa;• ~300 DOM nodes (10 posts)&#xa;• Initial render: 30-80ms&#xa;• Memory: only visible images&#xa;• Scroll: consistent 60fps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="650" width="230" height="120" as="geometry" />
        </mxCell>
        <mxCell id="edge-perf-no" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="perf-compare" target="perf-no">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-perf-yes" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="perf-compare" target="perf-yes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CSS alternative -->
        <mxCell id="css-alt" value="CSS Alternative: content-visibility: auto&#xa;&#xa;• Zero JS — one CSS property&#xa;• Browser skips off-screen layout/paint&#xa;• Use contain-intrinsic-size: auto 400px&#xa;• Chrome 85+, Firefox 125+, no Safari until 18" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#b7a500;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="810" width="310" height="110" as="geometry" />
        </mxCell>

        <!-- Decision matrix -->
        <mxCell id="dec-title" value="Decision Matrix" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="700" y="570" width="340" height="45" as="geometry" />
        </mxCell>

        <mxCell id="dec1" value="&lt; 20 posts&#xa;Plain DOM + loading=&quot;lazy&quot;&#xa;(no library needed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="650" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="dec2" value="20-50 posts&#xa;content-visibility: auto&#xa;(CSS only, zero JS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="650" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="dec3" value="50+ posts (infinite scroll)&#xa;Full virtualization&#xa;(@tanstack/react-virtual)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="650" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="edge-dec1" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="dec-title" target="dec1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-dec2" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="dec-title" target="dec2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-dec3" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="dec-title" target="dec3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Additional strategies -->
        <mxCell id="strat-title" value="Additional Scroll Strategies" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#356ebf;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="700" y="770" width="340" height="45" as="geometry" />
        </mxCell>

        <mxCell id="strat1" value="Scroll Position Restoration&#xa;(save firstVisiblePostId to&#xa; sessionStorage + scrollToIndex)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#356ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="850" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="strat2" value="New Posts Banner&#xa;(buffer new posts from SSE,&#xa; never auto-prepend mid-scroll)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb8c00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="850" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="strat3" value="Pull to Refresh (Mobile)&#xa;(touch handler when scrollY=0,&#xa; threshold: 80px)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1090" y="850" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="edge-strat1" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="strat-title" target="strat1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-strat2" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="strat-title" target="strat2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-strat3" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="strat-title" target="strat3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="Performance and Optimization" id="social-feed-perf-opt">
    <mxGraphModel dx="2200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="po-title" value="Social Feed — Performance, Caching, and Cross-Cutting Concerns" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=20;fontColor=#333333;" vertex="1" parent="1">
