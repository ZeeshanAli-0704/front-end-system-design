          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Note: SSE + Infinite scroll -->
        <mxCell id="note-sse" value="SSE: /api/feed/stream&#xa;→ buffers new posts&#xa;→ shows banner" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#b7a500;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="310" width="175" height="60" as="geometry" />
        </mxCell>

        <mxCell id="note-sentinel" value="rootMargin: 500px&#xa;→ preloads next page&#xa;before user reaches bottom" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#b7a500;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1060" y="310" width="200" height="60" as="geometry" />
        </mxCell>

