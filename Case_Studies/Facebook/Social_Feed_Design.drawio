          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="commentList" value="CommentList&#xa;(threaded, paginated per post)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb8c00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1110" y="540" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="edge-card-comments" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="postCard" target="commentList">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="createComment" value="CreateComment&#xa;(UserAvatar + Input + Post button)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb8c00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1370" y="540" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="edge-card-createcomment" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#356ebf;" edge="1" parent="1" source="postCard" target="createComment">
          <mxGeometry relative="1" as="geometry" />
