        <!-- CommentItem under CommentList -->
        <mxCell id="commentItem" value="CommentItem[]&#xa;(Avatar + Body + Actions + Replies)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb8c00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1110" y="630" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-comments-item" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#fb8c00;" edge="1" parent="1" source="commentList" target="commentItem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== ENGAGEMENT SUMMARY ==================== -->
        <mxCell id="engagementSummary" value="EngagementSummary&#xa;(&quot;12K likes · 340 comments&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#43a047;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="630" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="edge-actions-engagement" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;strokeColor=#43a047;" edge="1" parent="1" source="postActions" target="engagementSummary">
